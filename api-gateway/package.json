{
  "name": "api-gateway",
  "version": "1.0.0",
  "description": "API Gateway for microservices e-commerce platform",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node src/server.js",
    "test": "jest --forceExit --detectOpenHandles",
    "test:coverage": "jest --coverage --forceExit --detectOpenHandles"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "axios-retry": "^4.5.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.0",
    "helmet": "^8.1.0",
    "opossum": "^9.0.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^6.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/server.js"
    ]
  }
}
