# API Gateway
API_GATEWAY_PORT=8080

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Inter-Service Communication
INTERNAL_SERVICE_KEY=internal-service-secret-key-change-in-production

# Auth Service Database
AUTH_DB_HOST=auth-db
AUTH_DB_PORT=5432
AUTH_DB_NAME=auth_db
AUTH_DB_USER=postgres
AUTH_DB_PASSWORD=postgres
AUTH_DATABASE_URL=postgresql://postgres:postgres@auth-db:5432/auth_db

# Product Service Database
PRODUCT_DB_HOST=product-db
PRODUCT_DB_PORT=5432
PRODUCT_DB_NAME=product_db
PRODUCT_DB_USER=postgres
PRODUCT_DB_PASSWORD=postgres
PRODUCT_DATABASE_URL=postgresql://postgres:postgres@product-db:5432/product_db

# Order Service Database
ORDER_DB_HOST=order-db
ORDER_DB_PORT=5432
ORDER_DB_NAME=order_db
ORDER_DB_USER=postgres
ORDER_DB_PASSWORD=postgres
ORDER_DATABASE_URL=postgresql://postgres:postgres@order-db:5432/order_db

# Payment Service Database
PAYMENT_DB_HOST=payment-db
PAYMENT_DB_PORT=5432
PAYMENT_DB_NAME=payment_db
PAYMENT_DB_USER=postgres
PAYMENT_DB_PASSWORD=postgres
PAYMENT_DATABASE_URL=postgresql://postgres:postgres@payment-db:5432/payment_db
